// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("VENDEDOR") // ADMIN, VENDEDOR, CLIENTE
  phone     String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sales     Sale[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  displayName String?
  description String?
  icon        String?
  color       String?
  isActive    Boolean      @default(true)
  isSystem    Boolean      @default(false)
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(uuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String   // dashboard, products, categories, inventory, sales, orders, deliveries, users, forum, settings
  action    String   // view, create, edit, delete, export, moderate, manage_roles
  isEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, module, action])
}

model Sale {
  id          String   @id @default(uuid())
  productId   String   // ID del producto en MongoDB
  productName String
  quantity    Int
  price       Float
  total       Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
}

model Order {
  id            String   @id @default(uuid())
  productId     String   // ID del producto en MongoDB
  productName   String
  quantity      Int
  price         Float
  total         Float
  status        String   @default("PENDIENTE") // PENDING, PROCESSING, IN_ROUTE, DELIVERED, CANCELLED
  clientName    String
  clientPhone   String?
  clientAddress String?
  driverId      String?  // Vendedor o transportista asignado
  driverName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
