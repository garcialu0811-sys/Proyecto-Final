// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("VENDEDOR") // ADMIN, VENDEDOR, CLIENTE
  phone     String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sales     Sale[]
  orders    Order[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  displayName String?
  description String?
  icon        String?
  color       String?
  isActive    Boolean      @default(true)
  isSystem    Boolean      @default(false)
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(uuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String
  action    String
  isEnabled Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, module, action])
}

model Sale {
  id          String   @id @default(uuid())
  productId   String
  productName String
  quantity    Int
  price       Float
  total       Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
}

model Order {
  id            String   @id @default(uuid())
  orderNumber   String   @unique @default("")
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  productId     String
  productName   String
  quantity      Int
  price         Float
  total         Float
  status        String   @default("PENDIENTE")
  clientName    String
  clientPhone   String?
  clientAddress String?
  phone         String?
  address       String?
  city          String?
  zone          String?
  reference     String?
  paymentMethod String?
  subtotal      Float?
  shipping      Float?    @default(0)
  discount      Float?    @default(0)
  driverId      String?
  driverName    String?
  notes         String?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  items         OrderItem[]
  history       OrderHistory[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  sku         String?
  price       Float
  quantity    Int
  subtotal    Float
  image       String?
}

model OrderHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now())
}
